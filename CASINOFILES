<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=600, height=600, user-scalable=no" />
  <title>Casino Mania Deluxe</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div id="app"></div>
  <script src="input.js"></script>
  <script src="achievements.js"></script>
  <script src="app.js"></script>
</body>
</html>body {
  margin: 0;
  padding: 0;
  background: #111;
  color: white;
  font-family: Arial, sans-serif;
  width: 600px;
  height: 600px;
  overflow: hidden;
}

#app {
  width: 100%;
  height: 100%;
}

.title {
  text-align: center;
  font-size: 32px;
  margin-top: 10px;
  color: gold;
}

button {
  width: 80%;
  margin: 10px auto;
  display: block;
  padding: 12px;
  font-size: 22px;
  background: #222;
  color: white;
  border: 2px solid gold;
  border-radius: 8px;
}

button.focused {
  background: gold;
  color: black;
}

canvas:hover {
  cursor: crosshair;
}const app = document.getElementById("app");

let currentScreen = "opening";

function navigate(screen) {
  currentScreen = screen;

  if (screen === "opening") renderOpening();
  if (screen === "menu") renderRoundMenu();
  if (screen === "slots") renderSlots();
  if (screen === "blackjack") renderBlackjack();
  if (screen === "poker") renderPoker();
  if (screen === "baccarat") renderBaccarat();
  if (screen === "craps") renderCraps();
  if (screen === "keno") renderKeno();
  if (screen === "scratch") renderScratch();
  if (screen === "save") renderSave();
  if (screen === "load") renderLoad();
  if (screen === "vip") renderVIPRoom();
}

navigate("opening");window.addEventListener("keydown", e => {
  if (e.key === "ArrowDown") window.dispatchEvent(new Event("nav-down"));
  if (e.key === "ArrowUp") window.dispatchEvent(new Event("nav-up"));
  if (e.key === "Enter") window.dispatchEvent(new Event("nav-select"));
});let achievements = JSON.parse(localStorage.getItem("achievements") || "{}");

function unlockAchievement(name) {
  achievements[name] = true;
  localStorage.setItem("achievements", JSON.stringify(achievements));
}

function popupAchievement(text) {
  const box = document.createElement("div");
  box.style.position = "absolute";
  box.style.bottom = "20px";
  box.style.left = "50%";
  box.style.transform = "translateX(-50%)";
  box.style.padding = "10px 20px";
  box.style.background = "gold";
  box.style.color = "black";
  box.style.fontSize = "20px";
  box.style.borderRadius = "8px";
  box.textContent = text;

  app.appendChild(box);

  setTimeout(() => box.remove(), 2000);
}function renderOpening() {
  app.innerHTML = `
    <div style="text-align:center; margin-top:120px;">
      <div style="font-size:48px; color:gold; font-weight:bold;">
        CASINO MANIA
      </div>
      <div style="font-size:24px; margin-top:20px;">
        Deluxe Edition
      </div>
      <div style="margin-top:40px; font-size:18px;">
        Press ENTER to begin
      </div>
    </div>
  `;

  function start() {
    window.removeEventListener("nav-select", start);
    navigate("menu");
  }

  window.addEventListener("nav-select", start);
}let menuIndex = 0;

const menuItems = [
  { label: "🎰 Slots", screen: "slots" },
  { label: "🃏 Blackjack", screen: "blackjack" },
  { label: "🂡 Poker", screen: "poker" },
  { label: "🎴 Baccarat", screen: "baccarat" },
  { label: "🎲 Craps", screen: "craps" },
  { label: "🔢 Keno", screen: "keno" },
  { label: "🧽 Scratch Cards", screen: "scratch" },
  { label: "💾 Save Game", screen: "save" },
  { label: "📂 Load Game", screen: "load" },
  { label: "💎 VIP Room", screen: "vip" }
];

function renderRoundMenu() {
  app.innerHTML = `
    <div class="title">Casino Mania Deluxe</div>
    <div id="menu"></div>
  `;

  const menu = document.getElementById("menu");

  function drawMenu() {
    menu.innerHTML = "";
    menuItems.forEach((item, i) => {
      const btn = document.createElement("button");
      btn.textContent = item.label;
      if (i === menuIndex) btn.classList.add("focused");
      menu.appendChild(btn);
    });
  }

  drawMenu();

  function down() {
    menuIndex = (menuIndex + 1) % menuItems.length;
    drawMenu();
  }

  function up() {
    menuIndex = (menuIndex - 1 + menuItems.length) % menuItems.length;
    drawMenu();
  }

  function select() {
    navigate(menuItems[menuIndex].screen);
  }

  window.addEventListener("nav-down", down);
  window.addEventListener("nav-up", up);
  window.addEventListener("nav-select", select);
}function renderSave() {
  app.innerHTML = `
    <div class="title">Save Game</div>
    <button id="saveBtn">Save Progress</button>
    <button id="backBtn">Back</button>
  `;

  document.getElementById("saveBtn").onclick = () => {
    const data = {
      chips: window.playerChips || 1000,
      achievements,
      timestamp: Date.now()
    };

    localStorage.setItem("casinoSave", JSON.stringify(data));
    popupAchievement("Game Saved!");
  };

  document.getElementById("backBtn").onclick = () => navigate("menu");
}

function renderLoad() {
  app.innerHTML = `
    <div class="title">Load Game</div>
    <button id="loadBtn">Load Progress</button>
    <button id="backBtn">Back</button>
  `;

  document.getElementById("loadBtn").onclick = () => {
    const data = JSON.parse(localStorage.getItem("casinoSave") || "null");

    if (!data) {
      popupAchievement("No Save Found");
      return;
    }

    window.playerChips = data.chips;
    achievements = data.achievements || {};
    popupAchievement("Game Loaded!");
  };

  document.getElementById("backBtn").onclick = () => navigate("menu");
}function drawCenteredText(text, size = 28, color = "white", y = 300) {
  const div = document.createElement("div");
  div.style.position = "absolute";
  div.style.top = y + "px";
  div.style.left = "50%";
  div.style.transform = "translateX(-50%)";
  div.style.fontSize = size + "px";
  div.style.color = color;
  div.textContent = text;
  app.appendChild(div);
  return div;
}

function clearUI() {
  app.innerHTML = "";
}function renderSlots() {
  app.innerHTML = `
    <div class="title">Slots</div>
    <canvas id="slotCanvas" width="600" height="400" style="background:#222; margin-top:20px;"></canvas>
    <button id="spinBtn">SPIN</button>
    <button id="backBtn">Back</button>
  `;

  const canvas = document.getElementById("slotCanvas");
  const ctx = canvas.getContext("2d");

  const symbols = ["🍒", "🔔", "⭐", "7️⃣", "🍋"];
  let reels = ["?", "?", "?"];

  function drawReels() {
    ctx.clearRect(0, 0, 600, 400);
    ctx.font = "80px Arial";
    ctx.textAlign = "center";
    ctx.fillStyle = "white";

    ctx.fillText(reels[0], 150, 220);
    ctx.fillText(reels[1], 300, 220);
    ctx.fillText(reels[2], 450, 220);
  }

  drawReels();

  document.getElementById("spinBtn").onclick = () => {
    reels = [
      symbols[Math.floor(Math.random() * symbols.length)],
      symbols[Math.floor(Math.random() * symbols.length)],
      symbols[Math.floor(Math.random() * symbols.length)]
    ];

    drawReels();

    if (reels[0] === reels[1] && reels[1] === reels[2]) {
      popupAchievement("JACKPOT!");
      window.playerChips += 200;
    } else {
      window.playerChips -= 20;
    }
  };

  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderBlackjack() {
  app.innerHTML = `
    <div class="title">Blackjack</div>
    <div id="bjArea" style="text-align:center; margin-top:20px;"></div>
    <button id="hitBtn">Hit</button>
    <button id="standBtn">Stand</button>
    <button id="backBtn">Back</button>
  `;

  const area = document.getElementById("bjArea");

  let player = [];
  let dealer = [];

  function draw() {
    area.innerHTML = `
      <div>Dealer: ${dealer.join(" ")}</div>
      <div>Player: ${player.join(" ")}</div>
    `;
  }

  function card() {
    return Math.floor(Math.random() * 10) + 1;
  }

  function total(hand) {
    return hand.reduce((a, b) => a + b, 0);
  }

  function start() {
    player = [card(), card()];
    dealer = [card(), card()];
    draw();
  }

  start();

  document.getElementById("hitBtn").onclick = () => {
    player.push(card());
    draw();

    if (total(player) > 21) {
      popupAchievement("Bust!");
      window.playerChips -= 50;
    }
  };

  document.getElementById("standBtn").onclick = () => {
    while (total(dealer) < 17) dealer.push(card());
    draw();

    const p = total(player);
    const d = total(dealer);

    if (p > 21) {
      popupAchievement("You Lose");
      window.playerChips -= 50;
    } else if (d > 21 || p > d) {
      popupAchievement("You Win!");
      window.playerChips += 50;
    } else {
      popupAchievement("Dealer Wins");
      window.playerChips -= 50;
    }
  };

  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderPoker() {
  app.innerHTML = `
    <div class="title">Poker</div>
    <div id="pokerArea" style="text-align:center; margin-top:20px;"></div>
    <button id="drawBtn">Draw</button>
    <button id="backBtn">Back</button>
  `;

  const area = document.getElementById("pokerArea");

  let hand = [];

  function drawHand() {
    hand = [];
    for (let i = 0; i < 5; i++) {
      hand.push(Math.floor(Math.random() * 13) + 1);
    }
    area.innerHTML = `Hand: ${hand.join(" ")}`;
  }

  drawHand();

  document.getElementById("drawBtn").onclick = () => {
    drawHand();
    popupAchievement("New Hand!");
  };

  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderBaccarat() {
  app.innerHTML = `
    <div class="title">Baccarat</div>
    <div id="bacArea" style="text-align:center; margin-top:20px;"></div>
    <button id="dealBtn">Deal</button>
    <button id="backBtn">Back</button>
  `;

  const area = document.getElementById("bacArea");

  function draw() {
    const player = Math.floor(Math.random() * 9) + 1;
    const banker = Math.floor(Math.random() * 9) + 1;

    area.innerHTML = `
      Player: ${player}<br>
      Banker: ${banker}
    `;

    if (player > banker) {
      popupAchievement("Player Wins!");
      window.playerChips += 40;
    } else if (banker > player) {
      popupAchievement("Banker Wins!");
      window.playerChips -= 40;
    } else {
      popupAchievement("Tie!");
    }
  }

  document.getElementById("dealBtn").onclick = draw;
  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderCraps() {
  app.innerHTML = `
    <div class="title">Craps</div>
    <div id="crapsArea" style="text-align:center; margin-top:20px;"></div>
    <button id="rollBtn">Roll Dice</button>
    <button id="backBtn">Back</button>
  `;

  const area = document.getElementById("crapsArea");

  function roll() {
    const d1 = Math.floor(Math.random() * 6) + 1;
    const d2 = Math.floor(Math.random() * 6) + 1;
    const total = d1 + d2;

    area.innerHTML = `Dice: ${d1} + ${d2} = ${total}`;

    if (total === 7 || total === 11) {
      popupAchievement("You Win!");
      window.playerChips += 30;
    } else if (total === 2 || total === 3 || total === 12) {
      popupAchievement("Craps! You Lose");
      window.playerChips -= 30;
    }
  }

  document.getElementById("rollBtn").onclick = roll;
  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderKeno() {
  app.innerHTML = `
    <div class="title">Keno</div>
    <div id="kenoArea" style="text-align:center; margin-top:20px;"></div>
    <button id="playBtn">Play</button>
    <button id="backBtn">Back</button>
  `;

  const area = document.getElementById("kenoArea");

  function play() {
    const pick = Math.floor(Math.random() * 10) + 1;
    const draw = Math.floor(Math.random() * 10) + 1;

    area.innerHTML = `Your Pick: ${pick}<br>Draw: ${draw}`;

    if (pick === draw) {
      popupAchievement("Keno Hit!");
      window.playerChips += 100;
    } else {
      window.playerChips -= 10;
    }
  }

  document.getElementById("playBtn").onclick = play;
  document.getElementById("backBtn").onclick = () => navigate("menu");
}function renderScratch() {
  app.innerHTML = `
    <div class="title">Scratch Cards</div>
    <canvas id="scratchCanvas" width="600" height="400" style="background:#999; margin-top:20px;"></canvas>
    <button id="backBtn">Back</button>
  `;

  const canvas = document.getElementById("scratchCanvas");
  const ctx = canvas.getContext("2d");

  const prize = Math.random() < 0.3 ? "WIN $50" : "TRY AGAIN";

  ctx.fillStyle = "#444";
  ctx.fillRect(0, 0, 600, 400);

  canvas.addEventListener("mousemove", e => {
    if (e.buttons === 1) {
      const x = e.offsetX;
      const y = e.offsetY;
      ctx.clearRect(x - 20, y - 20, 40, 40);
    }
  });

  canvas.addEventListener("mouseup", () => {
    popupAchievement(prize);
    if (prize.includes("WIN")) window.playerChips += 50;
  });

  document.getElementById("backBtn").onclick = () => navigate("menu");
