if (!window.playerChips) window.playerChips = 1000;

function addChips(amount) {
  window.playerChips += amount;
  popupAchievement(`+${amount} Chips`);
}

function removeChips(amount) {
  window.playerChips -= amount;
  if (window.playerChips < 0) window.playerChips = 0;
  popupAchievement(`-${amount} Chips`);
}

function renderChipDisplay() {
  const chipDiv = document.createElement("div");
  chipDiv.style.position = "absolute";
  chipDiv.style.top = "10px";
  chipDiv.style.right = "10px";
  chipDiv.style.padding = "8px 14px";
  chipDiv.style.background = "rgba(0,0,0,0.6)";
  chipDiv.style.border = "2px solid gold";
  chipDiv.style.borderRadius = "8px";
  chipDiv.style.fontSize = "20px";
  chipDiv.style.color = "gold";
  chipDiv.id = "chipDisplay";
  chipDiv.textContent = `Chips: ${window.playerChips}`;
  app.appendChild(chipDiv);
}

function updateChipDisplay() {
  const chipDiv = document.getElementById("chipDisplay");
  if (chipDiv) chipDiv.textContent = `Chips: ${window.playerChips}`;
}function renderDailyBonus() {
  app.innerHTML = `
    <div class="title">Daily Bonus</div>
