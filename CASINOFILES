    addChips(reward);
    popupAchievement(`Daily Bonus: +${reward} Chips!`);

    document.getElementById("bonusArea").textContent =
      `You won ${reward} chips!`;
  }

  window.addEventListener("nav-select", spin, { once: true });
}function renderVIPRoom() {
  app.innerHTML = `
    <div class="title">VIP Room</div>
